# 复制本文件为 .env 并填写。

# LLM_PROVIDER 支持：anthropic / openai / deepseek / moonshot（kimi同） / qwen（dashscope同） / glm（zhipu同） / minimax / custom
# - anthropic：官方 Claude API
# - openai：官方 OpenAI API
# - deepseek / moonshot / qwen / glm / minimax：国内大模型，走 OpenAI 兼容协议，内置默认 base_url
# - custom：自定义 OpenAI 兼容端点，必须同时填写 LLM_BASE_URL
LLM_PROVIDER=deepseek

# 对应 provider 的 API Key
LLM_API_KEY=

# 模型名，按你选的 provider 填对应的模型标识，例如：
#   anthropic  -> claude-sonnet-4-5-20250929
#   openai     -> gpt-4o
#   deepseek   -> deepseek-chat
#   moonshot   -> moonshot-v1-8k
#   qwen       -> qwen-plus
#   glm        -> glm-4-plus
LLM_MODEL=deepseek-chat

# 可选：自定义 base_url，覆盖内置默认映射（custom provider 必填）
LLM_BASE_URL=

# 可选：单次调用最大 token 数，默认 4096
LLM_MAX_TOKENS=4096

# 可选：单次调用超时秒数，默认 120
LLM_TIMEOUT=120

# 可选：可重试错误（超时/限流）的重试次数，默认 1
LLM_MAX_RETRIES=1
